# Pantry Registry Configuration

# Server
PORT=3000
BASE_URL=https://registry.yourdomain.com

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# S3 Storage (for tarballs)
S3_BUCKET=pantry-registry-packages

# DynamoDB (for metadata)
DYNAMODB_TABLE=pantry-registry-metadata
DYNAMODB_ANALYTICS_TABLE=pantry-registry-analytics

# npm Fallback (set to false to disable)
NPM_FALLBACK=true

# Stripe (for package paywalls — optional)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Authentication
# Legacy admin token for CI publish (default: ABCD1234)
# PANTRY_REGISTRY_TOKEN=your-admin-token
# User auth uses the same DynamoDB table as metadata (DYNAMODB_TABLE above)
