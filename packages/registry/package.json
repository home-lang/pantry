{
  "name": "@stacksjs/registry",
  "version": "0.9.20",
  "type": "module",
  "description": "Pantry package registry backend - S3 storage with DynamoDB metadata",
  "author": "Stacks.js",
  "license": "MIT",
  "homepage": "https://github.com/home-lang/pantry/tree/main/packages/registry#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/home-lang/pantry.git",
    "directory": "packages/registry"
  },
  "bugs": {
    "url": "https://github.com/home-lang/pantry/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "test": "bun test",
    "test:analytics": "bun test src/analytics.test.ts",
    "test:commit-publish": "bun test src/commit-publish.test.ts",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "@stacksjs/stx": "^0.2.9",
    "@ts-charts/array": "^0.2.0",
    "@ts-charts/format": "^0.2.0",
    "@ts-charts/path": "^0.2.0",
    "@ts-charts/scale": "^0.2.0",
    "@ts-charts/shape": "^0.2.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.0"
  }
}
