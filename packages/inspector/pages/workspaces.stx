<script server>
  const { analyzeProject } = require('../lib/analyze.ts')
  const a = analyzeProject(process.env.PANTRY_PROJECT_ROOT || process.cwd())
  const projectName = a.projectName
  const projectRoot = a.projectRoot
  const workspaces = a.workspaces
</script>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Workspaces - {{ projectName }} - Pantry Inspector</title>
  <link href="https://cdn.jsdelivr.net/npm/@fontsource-variable/geist-sans@1/index.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/@fontsource-variable/geist-mono@1/index.min.css" rel="stylesheet" />
  <style>
    :root { --bg: oklch(0.171 0 0); --bg-subtle: oklch(0.198 0 0); --bg-muted: oklch(0.236 0 0); --fg: oklch(0.982 0 0); --fg-muted: oklch(0.749 0 0); --fg-subtle: oklch(0.673 0 0); --border: oklch(0.269 0 0); --accent: oklch(0.787 0.128 230.318); --green: oklch(0.792 0.153 166.95); --amber: oklch(0.828 0.165 84.429); }
    html { font-family: 'Geist Variable', system-ui, sans-serif; background: var(--bg); color: var(--fg); font-size: 15px; }
    body { min-height: 100vh; line-height: 1.6; margin: 0; }
    a { color: inherit; text-decoration: none; }
    .mono { font-family: 'Geist Mono Variable', monospace; }
    .ws-card { border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.25rem; background: var(--bg-subtle); }
  </style>
</head>
<body>
  <header class="border-b border-[var(--border)]" style="padding: 0.875rem 1.5rem;">
    <div class="max-w-5xl mx-auto flex items-center justify-between">
      <a href="/" class="mono text-sm" style="color: var(--accent);">← pantry inspector</a>
      <span class="mono text-xs" style="color: var(--fg-subtle);">{{ projectName }}</span>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-6 py-8">
    <h1 class="text-2xl font-semibold mono mb-2">Workspaces</h1>
    <p class="mono text-xs mb-8" style="color: var(--fg-subtle);">{{ workspaces.length }} workspace(s) in {{ projectRoot }}</p>

    <div class="flex flex-col gap-3">
      @foreach (workspaces as ws)
      <div class="ws-card">
        <div class="flex items-start justify-between gap-4 mb-2">
          <div>
            <p class="mono text-sm font-medium">{{ ws.name }}</p>
            <p class="mono text-xs mt-1" style="color: var(--fg-subtle);">{{ ws.path }}</p>
            @if (ws.version)
            <p class="mono text-xs mt-1" style="color: var(--fg-muted);">v{{ ws.version }}</p>
            @endif
          </div>
          <div class="flex gap-2 shrink-0">
            <span class="mono text-xs px-2 py-0.5 rounded" style="background: oklch(0.792 0.153 166.95 / 0.15); color: var(--green);">{{ ws.depCount }} prod</span>
            <span class="mono text-xs px-2 py-0.5 rounded" style="background: oklch(0.828 0.165 84.429 / 0.15); color: var(--amber);">{{ ws.devCount }} dev</span>
            @if (ws.systemCount > 0)
            <span class="mono text-xs px-2 py-0.5 rounded" style="background: oklch(0.787 0.128 230.318 / 0.15); color: var(--accent);">{{ ws.systemCount }} system</span>
            @endif
          </div>
        </div>
      </div>
      @endforeach
    </div>
  </main>
</body>
</html>
