<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  @if (title === 'pantry')
  <title>pantry - a fast, modern package manager</title>
  @else
  <title>{{ title }} - pantry</title>
  @endif
  <meta name="description" content="A fast, modern package manager for your system. Install pre-built binaries for open source tools with a single command." />

  <!-- Open Graph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="pantry" />
  @if (title === 'pantry')
  <meta property="og:title" content="pantry - a fast, modern package manager" />
  @else
  <meta property="og:title" content="{{ title }} - pantry" />
  @endif
  <meta property="og:description" content="A fast, modern package manager for your system. Install pre-built binaries for open source tools with a single command." />
  <meta property="og:url" content="https://pantry.dev" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="pantry - a fast, modern package manager" />
  <meta name="twitter:description" content="Install pre-built binaries for open source tools with a single command." />

  <!-- Favicon -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>&#x1F4E6;</text></svg>" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: oklch(0.171 0 0);
      --bg-subtle: oklch(0.198 0 0);
      --bg-muted: oklch(0.236 0 0);
      --bg-elevated: oklch(0.266 0 0);
      --fg: oklch(0.982 0 0);
      --fg-muted: oklch(0.749 0 0);
      --fg-subtle: oklch(0.673 0 0);
      --border: oklch(0.269 0 0);
      --border-hover: oklch(0.371 0 0);
      --accent: oklch(0.787 0.128 230.318);
      --accent-hover: oklch(0.85 0.128 230.318);
      --green: oklch(0.723 0.15 155);
      --yellow: oklch(0.795 0.15 85);
      --red: oklch(0.637 0.2 25);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-family: 'Inter', system-ui, -apple-system, sans-serif !important; background: var(--bg); color: var(--fg); -webkit-font-smoothing: antialiased; }
    body { min-height: 100vh; display: flex; flex-direction: column; }
    a { color: inherit; text-decoration: none; }
    code, .font-mono { font-family: 'JetBrains Mono', monospace !important; }

    /* Hover text color utilities (crosswind text-[var()] resolves to font-size, not color) */
    .hvr-fg:hover { color: var(--fg) !important; }
    .hvr-accent:hover { color: var(--accent-hover) !important; }

    @keyframes fade-in {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: none; }
    }
    .animate-fade-in { animation: fade-in 0.5s ease-out both; }
    .animate-fade-in-delay { animation: fade-in 0.5s ease-out 0.15s both; }
    .animate-fade-in-delay-2 { animation: fade-in 0.5s ease-out 0.3s both; }

    /* CSS-only tabs */
    .tab-radio { display: none; }
    .tab-label { cursor: pointer; padding: 0.5rem 1rem; font-size: 0.8125rem; color: var(--fg-subtle); border-bottom: 2px solid transparent; transition: all 0.2s; }
    .tab-label:hover { color: var(--fg-muted); }
    .tab-content { display: none; }
    .tab-radio:checked + .tab-label { color: var(--accent); border-bottom-color: var(--accent); }
    #tab-overview:checked ~ .tab-panel-overview,
    #tab-versions:checked ~ .tab-panel-versions,
    #tab-platforms:checked ~ .tab-panel-platforms { display: block; }

    /* Copy button */
    .copy-btn { cursor: pointer; background: none; border: 1px solid var(--border); border-radius: 0.375rem; padding: 0.25rem 0.5rem; color: var(--fg-subtle); font-size: 0.6875rem; transition: all 0.2s; }
    .copy-btn:hover { border-color: var(--border-hover); color: var(--fg-muted); }
    .copy-btn.copied { border-color: var(--green); color: var(--green); }

    /* Mobile header */
    .mobile-nav-toggle { display: none; background: none; border: none; color: var(--fg-muted); cursor: pointer; padding: 0.5rem; }
    @media (max-width: 640px) {
      .mobile-nav-toggle { display: block; }
      .header-nav { display: none; flex-direction: column; position: absolute; top: 3.5rem; left: 0; right: 0; background: var(--bg); border-bottom: 1px solid var(--border); padding: 1rem 1.5rem; gap: 0.75rem; }
      .header-nav.open { display: flex; }
      .header-nav form { width: 100%; }
      .header-nav form input { width: 100%; }
    }
  </style>
</head>
<body>
  <a class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-md skip-link" style="color: var(--bg); background: var(--accent);" href="#main-content">Skip to main content</a>

  <!-- Header -->
  <header class="sticky top-0 z-50 backdrop-blur-xl border-b border-[var(--border)]" style="background: color-mix(in oklch, var(--bg), transparent 10%);">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-14">
      <a href="/" class="flex items-center gap-2 font-semibold text-lg">
        <span style="color: var(--accent);">pantry</span>
      </a>
      <button class="mobile-nav-toggle" aria-label="Toggle navigation" onclick="this.nextElementSibling.classList.toggle('open')">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h14M3 10h14M3 15h14"/></svg>
      </button>
      <nav class="header-nav flex items-center gap-6 text-sm" aria-label="main navigation">
        <form action="/search" method="get" class="flex">
          <input
            type="text"
            name="q"
            placeholder="search packages..."
            aria-label="Search packages"
            class="bg-[var(--bg-subtle)] border border-[var(--border)] rounded-md px-3 py-1.5 w-60 outline-none transition-colors focus:border-[var(--accent)]"
            style="color: var(--fg); font-size: 0.8125rem;"
          />
        </form>
        <a href="/docs" class="hvr-fg transition-colors" style="color: var(--fg-muted);">docs</a>
        <a href="/about" class="hvr-fg transition-colors" style="color: var(--fg-muted);">about</a>
        <a href="https://github.com/home-lang/pantry" target="_blank" rel="noopener" class="hvr-fg transition-colors" style="color: var(--fg-muted);">github</a>
      </nav>
    </div>
  </header>

  <!-- Main -->
  <main id="main-content" class="flex-1 flex flex-col">
    {!! content !!}
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--border)] mt-auto py-8">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-wrap justify-between items-start gap-8">
        <div>
          <p class="text-sm" style="color: var(--fg-muted);">a fast, modern package manager for your system</p>
          <p class="text-xs mt-2" style="color: var(--fg-subtle);">built by <a href="https://stacksjs.com" class="hvr-accent transition-colors" style="color: var(--accent);">Stacks.js</a></p>
        </div>
        <nav class="flex gap-6" style="font-size: 0.8125rem; color: var(--fg-muted);" aria-label="footer navigation">
          <a href="/docs" class="hvr-fg transition-colors">docs</a>
          <a href="/about" class="hvr-fg transition-colors">about</a>
          <a href="/privacy" class="hvr-fg transition-colors">privacy</a>
          <a href="/accessibility" class="hvr-fg transition-colors">accessibility</a>
          <a href="https://github.com/home-lang/pantry" target="_blank" rel="noopener" class="hvr-fg transition-colors">source</a>
          <a href="https://discord.gg/stacksjs" target="_blank" rel="noopener" class="hvr-fg transition-colors">chat</a>
        </nav>
      </div>
    </div>
  </footer>
</body>
</html>
