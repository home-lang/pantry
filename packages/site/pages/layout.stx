<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  @if (title === 'pantry')
  <title>pantry - a fast, modern package manager</title>
  @else
  <title>{{ title }} - pantry</title>
  @endif
  <meta name="description" content="A fast, modern package manager for your system" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: oklch(0.171 0 0);
      --bg-subtle: oklch(0.198 0 0);
      --bg-muted: oklch(0.236 0 0);
      --bg-elevated: oklch(0.266 0 0);
      --fg: oklch(0.982 0 0);
      --fg-muted: oklch(0.749 0 0);
      --fg-subtle: oklch(0.673 0 0);
      --border: oklch(0.269 0 0);
      --border-hover: oklch(0.371 0 0);
      --accent: oklch(0.787 0.128 230.318);
      --accent-hover: oklch(0.85 0.128 230.318);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-family: 'Inter', system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--fg); -webkit-font-smoothing: antialiased; }
    body { min-height: 100vh; display: flex; flex-direction: column; }
    a { color: inherit; text-decoration: none; }
    code, .font-mono { font-family: 'JetBrains Mono', monospace; }
    .container { width: 100%; max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }
    .skip-link { position: absolute; top: -100%; left: 1rem; padding: 0.5rem 1rem; background: var(--accent); color: var(--bg); border-radius: 0.375rem; z-index: 100; font-weight: 500; }
    .skip-link:focus { top: 0.5rem; }
  </style>
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <!-- Header -->
  <header style="position: sticky; top: 0; z-index: 50; background: color-mix(in oklch, var(--bg), transparent 10%); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border);">
    <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 3.5rem;">
      <a href="/" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; font-size: 1.125rem;">
        <span style="color: var(--accent);">pantry</span>
      </a>
      <nav style="display: flex; align-items: center; gap: 1.5rem; font-size: 0.875rem;" aria-label="main navigation">
        <form action="/search" method="get" style="display: flex;">
          <input type="text" name="q" placeholder="search packages..." aria-label="Search packages" style="background: var(--bg-subtle); border: 1px solid var(--border); border-radius: 0.375rem; padding: 0.375rem 0.75rem; color: var(--fg); font-size: 0.8125rem; width: 15rem; outline: none; transition: border-color 0.15s;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
        </form>
        <a href="/about" style="color: var(--fg-muted); transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-muted)'">about</a>
        <a href="https://github.com/nicholasgasior/pantry" target="_blank" rel="noopener" style="color: var(--fg-muted); transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-muted)'">github</a>
      </nav>
    </div>
  </header>

  <!-- Main -->
  <main id="main-content" style="flex: 1; display: flex; flex-direction: column;">
    {!! content !!}
  </main>

  <!-- Footer -->
  <footer style="border-top: 1px solid var(--border); margin-top: auto; padding: 2rem 0;">
    <div class="container">
      <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-start; gap: 2rem;">
        <div>
          <p style="color: var(--fg-muted); font-size: 0.875rem;">a fast, modern package manager for your system</p>
          <p style="color: var(--fg-subtle); font-size: 0.75rem; margin-top: 0.5rem;">built by <a href="https://stacksjs.org" style="color: var(--accent);">Stacks.js</a></p>
        </div>
        <nav style="display: flex; gap: 1.5rem; font-size: 0.8125rem; color: var(--fg-muted);" aria-label="footer navigation">
          <a href="/about" style="transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-muted)'">about</a>
          <a href="/privacy" style="transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-muted)'">privacy</a>
          <a href="/accessibility" style="transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-muted)'">accessibility</a>
          <a href="https://github.com/nicholasgasior/pantry" target="_blank" rel="noopener" style="transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-muted)'">source</a>
          <a href="https://discord.gg/stacksjs" target="_blank" rel="noopener" style="transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-muted)'">chat</a>
        </nav>
      </div>
    </div>
  </footer>
</body>
</html>
